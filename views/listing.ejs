<% layout('/layout/boilerplate') -%>

    <body>

        <h1>All List of Hotels..</h1>
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mb-4">
            <%for(let item of list){%>
                <a href="/listings/<%=item._id%>" class="card-link">
                    <div class="card col">
                        <img src="<%=item.image.url%>" class="card-img-top" alt="..." style="height: 20rem;">
                        <div class="card-img-overlay"></div>
                        <div class="card-body">
                            <p class="card-text">
                                <b>
                                    <%= item.title %>
                                </b><br>
                                &#8377;<%= item.price ? item.price.toLocaleString("en-IN") : "N/A" %>/night



                        </div>
                    </div>
                </a>



                <% }%>
        </div>

    </body>