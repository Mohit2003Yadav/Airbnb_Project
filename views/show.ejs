<% layout('/layout/boilerplate') -%>
  <script>
     const mapToken = "<%= process.env.MAP_TOKEN %>";
     const listing = <%- JSON.stringify(item) %>;
     const bookedRanges = <%- JSON.stringify(bookedRanges || []) %>;
  </script>

  <body>
    <div class="row">
      <div class="col-8 offset-2 mt-4">
        <h3>
          <%=item.title%>
        </h3>
      </div>
      <div class="col-12 col-lg-6 offset-lg-2">
        <div class="card show-card listing-card">
          <img src="<%=item.image.url%>" class="card-img-top show-img" alt="...">
          <div class="card-body">
            <p class="card-text">
              <i>
                <%=item.owner.username %>
              </i>
            </p>
            <p class="card-text">
              <%=item.description%>
            </p>
            <p class="card-text">
              <%=item.location%>
            </p>
            <p class="card-text">
              <%=item.country%>
            </p>
            <p class="card-text"> &#8377;<%=item.price%>
            </p>


          </div>


        </div>
        <% if(currUser && currUser._id.equals(item.owner._id)) { %>
          <div class="btns d-flex gap-3 mt-3">
            <a class="btn btn-danger" href="/listings/<%=item._id%>/edit">Edit</a>
            <form action="/listings/<%=item._id%>/delete/?_method=DELETE" method="post" class="d-inline">
              <button class="btn btn-danger">Delete</button>
            </form>
          </div>
          <%}%>

      </div>

      <div class="col-12 col-lg-4 mt-4">
        <div class="card booking-panel">
          <div class="card-body">
            <h5 class="card-title mb-3">Book this stay</h5>
            <p class="mb-3">&#8377;<%= item.price.toLocaleString("en-IN") %> <span class="text-muted">/ night</span></p>

            <% if(currUser && !currUser._id.equals(item.owner._id)) { %>
              <form action="/listings/<%=item._id%>/bookings" method="POST" novalidate class="needs-validation booking-form">
                <div class="mb-3">
                  <label for="checkIn" class="form-label">Check-in</label>
                  <input type="date" id="checkIn" name="booking[checkIn]" class="form-control" required>
                  <div class="invalid-feedback">Please select a check-in date.</div>
                </div>

                <div class="mb-3">
                  <label for="checkOut" class="form-label">Check-out</label>
                  <input type="date" id="checkOut" name="booking[checkOut]" class="form-control" required>
                  <div class="invalid-feedback">Please select a check-out date.</div>
                </div>

                <div class="mb-3">
                  <label for="guests" class="form-label">Guests</label>
                  <input type="number" id="guests" name="booking[guests]" class="form-control" min="1" max="20" value="1" required>
                  <div class="invalid-feedback">Please enter at least 1 guest.</div>
                </div>

                <button class="btn btn-danger w-100">Reserve</button>
              </form>

              <div class="availability-box mt-4">
                <h6 class="mb-3">Availability</h6>
                <div id="availabilityCalendar" class="availability-calendar"></div>
                <p id="bookingDateError" class="text-danger small mt-3 mb-0 d-none"></p>
              </div>
            <% } else if(currUser && currUser._id.equals(item.owner._id)) { %>
              <p class="text-muted mb-0">Owners cannot book their own listing.</p>
            <% } else { %>
              <a href="/login" class="btn btn-danger w-100">Login to reserve</a>
            <% } %>
          </div>
        </div>
      </div>


      <div class="col-8 offset-2 mt-3 mb-3">
        <% if(currUser){ %>
          <hr>
          <h3>Reviews</h3>

          <form action="/listings/<%=item._id%>/reviews" method="POST" novalidate class="needs-validation">

            <div class="mb-3 mt-3">
              <label for="rating" class="form-label">Rating</label>
              <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0" checked
                  aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
              </fieldset>
            </div>

            <div class="mb-3 mt-3">
              <label for="comment" class="form-label"> Comments</label>
              <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>

              <div class="invalid-feedback">
                Please give your valuable feedback
              </div>
            </div>
            <button class="btn btn-outline-dark">Submit</button>
          </form>
          <%} %>
      </div>
    </div>
    <hr>
    <%if(item.reviews.length> 0){%>
      <div class="row">
        <div class="col-8 offset-2 mt-4">


          <div class="row">
            <h4>All Reviews</h4>
            <% for(let rev of item.reviews){ %>
              <div class="card col-5 ms-2 mb-3 mr-4 mx-4 mb-4">
                <div class="card-body">
                  <h5 class="card-title">
                    <i>
                      <% if (rev.author && rev.author.username) { %>
                        @<%= rev.author.username %>
                          <% } else { %>
                            @Unknown
                            <% } %>
                    </i>
                  </h5>
                  <p class="card-title">Rating: <%=rev.rating%>/5</p>
                  <p class="starability-result" data-rating="<%=rev.rating%>">
                    Rated: <%=rev.rating%> stars
                  </p>
                  <p class="card-text">
                    <%=rev.comment%>
                  </p>
                </div>
                <form action="/listings/<%=item._id%>/reviews/<%=rev._id%>?_method=DELETE" class="mb-3 ms-3"
                  method="post">
                  <button class="btn btn-danger">Delete</button>
                </form>
              </div>
              <% } %>
          </div>
          <% } %>
        </div>
        <div class='col-8 offset-2 mt-3 mb-3'>
          <h3>Where you'll be</h3>
          <div id="map">
          </div>
        </div>
      </div>
    

      <script src="/js/map.js"></script>
      <script src="/js/booking-calendar.js"></script>
  </body>
