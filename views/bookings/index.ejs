<% layout('/layout/boilerplate') -%>

<div class="row mt-4">
  <div class="col-12 col-lg-10 offset-lg-1">
    <h3 class="mb-4">My Bookings</h3>

    <% if (bookings.length === 0) { %>
      <div class="alert alert-light border">
        You do not have any bookings yet.
      </div>
    <% } %>

    <div class="row">
      <% for (let booking of bookings) { %>
        <div class="col-12 mb-3">
          <div class="card booking-card">
            <div class="row g-0">
              <div class="col-md-4">
                <% if (booking.listing && booking.listing.image) { %>
                  <img
                    src="<%= booking.listing.image.url %>"
                    class="img-fluid booking-img"
                    alt="<%= booking.listing.title %>"
                  >
                <% } %>
              </div>
              <div class="col-md-8">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap">
                    <div>
                      <h5 class="card-title mb-1">
                        <% if (booking.listing) { %>
                          <a href="/listings/<%= booking.listing._id %>" class="text-decoration-none text-dark">
                            <%= booking.listing.title %>
                          </a>
                        <% } else { %>
                          Listing removed
                        <% } %>
                      </h5>
                      <% if (booking.listing) { %>
                        <p class="text-muted mb-2"><%= booking.listing.location %>, <%= booking.listing.country %></p>
                      <% } %>
                    </div>
                    <span class="badge <%= booking.status === 'confirmed' ? 'text-bg-success' : 'text-bg-secondary' %>">
                      <%= booking.status %>
                    </span>
                  </div>

                  <div class="booking-details mt-3">
                    <p><b>Check-in:</b> <%= booking.checkIn.toDateString() %></p>
                    <p><b>Check-out:</b> <%= booking.checkOut.toDateString() %></p>
                    <p><b>Guests:</b> <%= booking.guests %></p>
                    <p><b>Total:</b> &#8377;<%= booking.totalPrice.toLocaleString("en-IN") %></p>
                  </div>

                  <% if (booking.status === "confirmed") { %>
                    <form action="/bookings/<%= booking._id %>/cancel?_method=PATCH" method="POST" class="mt-3">
                      <button class="btn btn-outline-danger btn-sm">Cancel booking</button>
                    </form>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>
